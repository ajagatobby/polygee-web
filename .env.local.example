# ─── Backend API ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Firebase (client-side) ────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Stripe ────────────────────────────────────────────────────────────
# Publishable key (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Price IDs from your Stripe Dashboard (Products > Prices)
# Monthly = $99/month, Yearly = $831.60/year ($69.30/month, 30% off)
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_xxx

# Server-side (for API routes / webhooks — used by backend, not Next.js)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
